# Copy to .env (or .env.development) and fill in. On Railway, set these in the service Variables tab.

NODE_ENV=development
PORT=5050
FRONTEND_URL=http://localhost:5173

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mittikala

# Redis (optional — cache silently disabled if unreachable)
REDIS_URL=redis://localhost:6379

# JWT secrets (generate: openssl rand -hex 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=orders@mittikala.com

# SMS (Twilio, optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# AI support chat / search (optional)
ANTHROPIC_API_KEY=
